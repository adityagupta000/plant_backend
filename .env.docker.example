# Docker Environment Variables Example
# This file is for REFERENCE ONLY and shows all available configuration options
# DO NOT commit actual secrets - use Docker Secrets in secrets/ directory instead
# See docs/DOCKER_SETUP.md for detailed documentation

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# =============================================================================
# Database (Default: SQLite, can switch to PostgreSQL)
# =============================================================================
DB_PATH=/app/data/database.sqlite
DB_DIALECT=sqlite
DB_LOGGING=false

# PostgreSQL Configuration (uncomment to use)
# DB_DIALECT=postgres
# DB_HOST=postgres-service
# DB_PORT=5432
# DB_NAME=plant_health
# DB_USER=postgres
# DB_PASSWORD=your-secure-password

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD is loaded from Docker Secrets, not here!

# =============================================================================
# JWT Token Configuration (Expiration times, not secrets)
# =============================================================================
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
REFRESH_TOKEN_COOKIE_NAME=refreshToken
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Security Settings
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000
MIN_JWT_SECRET_LENGTH=32

# JWT secrets are loaded from Docker Secrets:
# - /run/secrets/jwt_access_secret
# - /run/secrets/jwt_refresh_secret
# These should be generated using:
# openssl rand -hex 32 > secrets/jwt_access_secret.txt
# openssl rand -hex 32 > secrets/jwt_refresh_secret.txt

# =============================================================================
# AI Service Configuration
# =============================================================================
PYTHON_PATH=/usr/local/bin/python
MODEL_PATH=/app/ai/saved_models/best_model.encrypted
MODEL_KEY_PATH=/app/ai/secrets/model.key
AI_WORKERS=4
AI_SERVICE_TIMEOUT=30000
AI_SERVICE_MAX_RETRIES=3
AI_SERVICE_RETRY_DELAY=1000
AI_MAX_OUTPUT_SIZE=1048576

# =============================================================================
# File Upload Configuration
# =============================================================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg
ALLOWED_EXTENSIONS=jpg,jpeg,png
STORAGE_TYPE=local

# =============================================================================
# Guest Mode Configuration
# =============================================================================
GUEST_MODE_ENABLED=true
GUEST_PREDICTION_LIMIT=10
GUEST_IP_LIMIT=2
GUEST_FINGERPRINT_LIMIT=10
GUEST_SESSION_LIMIT=4
GUEST_IP_WINDOW_MS=3600000
GUEST_FINGERPRINT_WINDOW_MS=86400000
GUEST_RAPID_REQUEST_THRESHOLD=5
GUEST_RAPID_REQUEST_BLOCK_MS=900000
GUEST_PDF_DOWNLOAD_ENABLED=false

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
GLOBAL_RATE_WINDOW_MS=900000
GLOBAL_RATE_MAX=1000
PREDICTION_RATE_WINDOW_MS=900000
PREDICTION_RATE_MAX=50
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=10
HEALTH_RATE_WINDOW_MS=60000
HEALTH_RATE_MAX=10

# =============================================================================
# Storage & Cleanup Configuration
# =============================================================================
TEMP_FILE_CLEANUP=true
CLEANUP_DELAY_MS=10000

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=error

# =============================================================================
# Feature Flags
# =============================================================================
PDF_DOWNLOAD_ENABLED=true
HISTORY_TRACKING_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=false
CLOUD_STORAGE_ENABLED=false
ANALYTICS_ENABLED=false

# =============================================================================
# Timeout Configuration
# =============================================================================
REQUEST_TIMEOUT=30000
DB_QUERY_TIMEOUT=10000
FILE_UPLOAD_TIMEOUT=60000
AI_HEALTH_CHECK_TIMEOUT=5000
PDF_GENERATION_TIMEOUT=15000

# =============================================================================
# Development/Debugging (Local only)
# =============================================================================
# Only use these for local development with docker compose
# These are OVERRIDDEN by docker-compose.yml environment section

# Example fallback secrets (NOT USED - defined in secrets/ directory):
# ACCESS_TOKEN_SECRET=your-development-secret-here
# REFRESH_TOKEN_SECRET=your-development-secret-here
# REDIS_PASSWORD=your-redis-password-here

# =============================================================================
# NOTES
# =============================================================================
# 1. For Docker: Use docker-compose up --build
# 2. Secrets in secrets/ directory are auto-loaded
# 3. Do NOT commit .env.docker or secrets/ to Git
# 4. See DOCKER_SETUP.md for complete documentation
# 5. See docker-compose.yml for actual configuration
